# ═══════════════════════════════════════════
# bio.dev — Environment Variables
# ═══════════════════════════════════════════
# Copy this file as ".env.local" and fill in your values.
#
# For local development:
#   cp .env.example .env.local
#
# For production (Vercel):
#   Set these in your Vercel project settings.

# ─── REQUIRED ────────────────────────────────

# Database connection URL
# SQLite (local dev):  file:./prisma/dev.db
# PostgreSQL (prod):   postgresql://user:pass@host:5432/dbname
DATABASE_URL="file:./prisma/dev.db"

# NextAuth session encryption secret
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"

# ─── OPTIONAL ────────────────────────────────

# Application URL (auto-detected on Vercel)
# AUTH_URL=http://localhost:3000
